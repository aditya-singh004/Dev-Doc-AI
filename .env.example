# Copy to .env and fill in values.
# cp .env.example .env

# --- Core API ---
DEBUG=false
HOST=0.0.0.0
PORT=8000
APP_NAME=AI Documentation Chatbot
APP_VERSION=1.0.0

# --- LLM ( /api/v1/query and embeddings ) ---
# openai | gemini | local
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-pro

# --- LlamaIndex / RAG ---
EMBEDDING_MODEL=text-embedding-ada-002
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
DOCS_DIRECTORY=./docs
INDEX_STORAGE_PATH=./storage/index
AUTO_INGEST_ON_STARTUP=true

# --- Vector store: local | pinecone | auto ---
# local = disk under INDEX_STORAGE_PATH
# pinecone = hosted index (requires PINECONE_API_KEY + PINECONE_INDEX_NAME)
# auto = use Pinecone when API key and index name are set, else local
VECTOR_STORE=local
PINECONE_API_KEY=
PINECONE_INDEX_NAME=dda-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Leave empty to infer from EMBEDDING_MODEL (ada-002 / 3-small = 1536)
PINECONE_DIMENSION=
PINECONE_METRIC=cosine
PINECONE_NAMESPACE=
PINECONE_CREATE_INDEX=true

# --- Slack (optional; backend direct integration) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=

# --- Conversation memory ( /api/v1/query transcript ) ---
ENABLE_MEMORY=true
MAX_CONVERSATION_HISTORY=10

# --- Autonomous agent ( POST /api/v1/agent/run ) ---
# Requires OPENAI_API_KEY. Uses OpenAI tool calling (independent of LLM_PROVIDER for the loop).
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOOL_CALLS=20
AGENT_MAX_WORKING_MEMORY_UPDATES=10
AGENT_OPENAI_MODEL=
AGENT_TOOL_TIMEOUT_SEC=30
AGENT_RATE_LIMIT_PER_MINUTE=30
AGENT_TRACE_PERSIST=true
AGENT_TRACE_DIR=./logs/agent_traces
# Shared secret: UI/n8n sends approval_secret + allow_sensitive_tools to enable slack_post_message tool
AGENT_APPROVAL_SECRET=
AGENT_HTTP_ALLOWLIST_HOSTS=
AGENT_HTTP_MAX_BYTES=524288
SLACK_POST_CHANNEL_ALLOWLIST=
AGENT_WORKING_MEMORY_ENABLED=true
AGENT_WORKING_MEMORY_TTL_HOURS=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# --- n8n (docker-compose only; passed into n8n container) ---
# true = Slack workflow calls /api/v1/agent/run; false = /api/v1/query
DDA_USE_AGENT=true
# If true and DDA_AGENT_APPROVAL_SECRET is set, n8n forwards it (matches AGENT_APPROVAL_SECRET on chatbot)
DDA_AGENT_ALLOW_SENSITIVE=false
DDA_AGENT_APPROVAL_SECRET=

# --- Docker Compose extras ---
N8N_USER=admin
N8N_PASSWORD=admin
N8N_WEBHOOK_URL=http://localhost:5678
